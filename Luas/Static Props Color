local ref = gui.Reference("Misc", "General", "Extra")
local colorprops_enable = gui.Checkbox(ref, "misc.visuals.neon_props", "Static Props Color", false)

ffi.cdef[[
    void* GetModuleHandleA(const char* lpModuleName);
    void* GetProcAddress(void* hModule, const char* lpProcName);
]]

local FCVAR_CHEAT = 16384

local function GetInterface(dll, name)
    local module = ffi.C.GetModuleHandleA(dll)
    if module == nil then return nil end
    local ci_addr = ffi.C.GetProcAddress(module, "CreateInterface")
    if ci_addr == nil then return nil end
    local ci = ffi.cast("void*(__cdecl*)(const char*, int*)", ci_addr)
    return ci(name, nil)
end

local icvar = GetInterface("vstdlib.dll", "VEngineCvar007")
if not icvar then return end

local find_var_fn = ffi.cast("void*(__thiscall*)(void*, const char*)", ffi.cast("uintptr_t**", icvar)[0][13])

local function SetupConVar(name)
    local ptr = find_var_fn(icvar, name)
    if ptr == nil or ffi.cast("uintptr_t", ptr) == 0 then return nil end
    
    return {
        ptr = ptr,
        SetFloat  = ffi.cast("void(__thiscall*)(void*, float)", ffi.cast("uintptr_t**", ptr)[0][13]),
        RemoveFlags = ffi.cast("void(__thiscall*)(void*, int)", ffi.cast("uintptr_t**", ptr)[0][4])
    }
end

local cv_props = SetupConVar("r_colorstaticprops")
if cv_props then cv_props.RemoveFlags(cv_props.ptr, FCVAR_CHEAT) end

local last_state = false

callbacks.Register("CreateMove", "r_colorprops_logic", function(cmd)
    local enabled = colorprops_enable:GetValue()
    
    if enabled == last_state then return end
    last_state = enabled

    if enabled then
        if cv_props then cv_props.SetFloat(cv_props.ptr, 1.0) end 
    else
        if cv_props then cv_props.SetFloat(cv_props.ptr, 0.0) end 
    end
end)

callbacks.Register("Unload", function()
    if cv_props then cv_props.SetFloat(cv_props.ptr, 0.0) end
end)
