    return true
end

local function CreateTrampoline(fn, n)
    local t = ffi.C.VirtualAlloc(nil, TRAMPOLINE_SIZE, MEM_COMMIT + MEM_RESERVE, PAGE_EXECUTE_READWRITE)
    if not t then return nil end
    for i = 0, TRAMPOLINE_SIZE - 1 do ffi.cast("uint8_t*", t)[i] = 0x90 end
    ffi.C.memcpy(t, ffi.cast("const void*", fn), n)
    local jmp = ffi.cast("uint8_t*", t) + n
    jmp[0] = 0x68
    ffi.cast("uint32_t*", jmp + 1)[0] = ffi.cast("uint32_t", ffi.cast("uint8_t*", fn) + n)
    jmp[5] = 0xC3
    return t
end

