        void* GetModuleHandleA(const char* lpModuleName);
        void* GetProcAddress(void* hModule, const char* lpProcName);
    ]]
end)

local FCVAR_CHEAT = 16384

local function GetInterface(dll, name)
    local module = ffi.C.GetModuleHandleA(dll)
    if not module then return nil end
    local ci = ffi.cast("void*(__cdecl*)(const char*, int*)",
        ffi.C.GetProcAddress(module, "CreateInterface"))
    if not ci then return nil end
    return ci(name, nil)
end

local icvar = GetInterface("vstdlib.dll", "VEngineCvar007")
if not icvar then print("[Ragdoll] ICvar null") return end

local find_var_fn = ffi.cast("void*(__thiscall*)(void*, const char*)",
    ffi.cast("uintptr_t**", icvar)[0][13])

local function FindConVar(name)
    local ok, ptr = pcall(function() return find_var_fn(icvar, name) end)
    if not ok or not ptr then return nil end
    if ffi.cast("uintptr_t", ptr) == 0 then return nil end
    return ptr
end

local function RemoveCheatFlag(cv)
    if not cv then return end
    local fn = ffi.cast("void(__thiscall*)(void*, int)",
        ffi.cast("uintptr_t**", cv)[0][4])
    pcall(fn, cv, FCVAR_CHEAT)
end

local function SetConVarInt(cv, val)
    if not cv then return end
    local fn = ffi.cast("void(__thiscall*)(void*, float)",
        ffi.cast("uintptr_t**", cv)[0][13])
    pcall(fn, cv, val)
end

local cv_rag = FindConVar("cl_ragdoll_gravity")
if cv_rag then
    RemoveCheatFlag(cv_rag)
    print("[Ragdoll] cvar found, flag sokudu")
else
    print("[Ragdoll] cvar null")
    return
end

local is_dead_state = false

callbacks.Register("CreateMove", "ragdoll_logic", function(cmd)
    if not rag_enable:GetValue() then return end
    local lp = entities.GetLocalPlayer()
    if not lp then return end

    if not lp:IsAlive() then
        if not is_dead_state then
            SetConVarInt(cv_rag, rag_value:GetValue())
            is_dead_state = true
        end
    else
        if is_dead_state then
            SetConVarInt(cv_rag, 600)
            is_dead_state = false
        end
    end
end)

callbacks.Register("Unload", function()
    SetConVarInt(cv_rag, 600)
    is_dead_state = false
end)

