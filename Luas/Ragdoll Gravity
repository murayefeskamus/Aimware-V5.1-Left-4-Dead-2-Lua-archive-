local ref        = gui.Reference("Misc", "General", "Extra")
local rag_enable = gui.Checkbox(ref, "rag.enable", "Custom Ragdoll Gravity", false)
local rag_value  = gui.Slider(ref, "rag.value", "Gravity Value", 600, -1000, 1000)

