local function XOR_Decrypt(cipher, key)
    local result = {}
    for i = 1, #cipher do
        local key_char = key:byte(((i - 1) % #key) + 1)
        local cipher_char = cipher:byte(i)
        table.insert(result, string.char(bit.bxor(cipher_char, key_char)))
    end
    return table.concat(result)
end

