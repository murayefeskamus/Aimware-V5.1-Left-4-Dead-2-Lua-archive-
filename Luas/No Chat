no chudchat


local ref = gui.Reference("Misc", "General", "Extra")

local no_chat_enable = gui.Checkbox(ref, "misc.visuals.no_chat", "No Chat", false)
local no_hands_enable = gui.Checkbox(ref, "misc.visuals.no_hands", "No Hands (doesnt dork)", false)

ffi.cdef[[
    void* GetModuleHandleA(const char* lpModuleName);
    void* GetProcAddress(void* hModule, const char* lpProcName);
]]

local FCVAR_CHEAT = 16384

local function GetInterface(dll, name)
    local module = ffi.C.GetModuleHandleA(dll)
    if module == nil then return nil end
    local ci_addr = ffi.C.GetProcAddress(module, "CreateInterface")
    if ci_addr == nil then return nil end
    local ci = ffi.cast("void*(__cdecl*)(const char*, int*)", ci_addr)
    return ci(name, nil)
end

local icvar = GetInterface("vstdlib.dll", "VEngineCvar007")
if not icvar then return end

local find_var_fn = ffi.cast("void*(__thiscall*)(void*, const char*)", ffi.cast("uintptr_t**", icvar)[0][13])

local function SetupConVar(name)
    local ptr = find_var_fn(icvar, name)
    if ptr == nil or ffi.cast("uintptr_t", ptr) == 0 then return nil end
    
    return {
        ptr = ptr,
        SetFloat  = ffi.cast("void(__thiscall*)(void*, float)", ffi.cast("uintptr_t**", ptr)[0][13]),
        RemoveFlags = ffi.cast("void(__thiscall*)(void*, int)", ffi.cast("uintptr_t**", ptr)[0][4])
    }
end

local cv_chat_time   = SetupConVar("hud_saytext_time")
local cv_vmodel_fov  = SetupConVar("viewmodel_fov")

if cv_chat_time then cv_chat_time.RemoveFlags(cv_chat_time.ptr, FCVAR_CHEAT) end
if cv_vmodel_fov then cv_vmodel_fov.RemoveFlags(cv_vmodel_fov.ptr, FCVAR_CHEAT) end

local last_chat_state = false
local last_hands_state = false

callbacks.Register("CreateMove", "chat_and_hands_logic", function(cmd)
    local chat_enabled  = no_chat_enable:GetValue()
    local hands_enabled = no_hands_enable:GetValue()

    if chat_enabled ~= last_chat_state then
        last_chat_state = chat_enabled
        if cv_chat_time then
            cv_chat_time.SetFloat(cv_chat_time.ptr, chat_enabled and 0.0 or 12.0)
        end
    end

    if hands_enabled ~= last_hands_state then
        last_hands_state = hands_enabled
        if cv_vmodel_fov then
            cv_vmodel_fov.SetFloat(cv_vmodel_fov.ptr, hands_enabled and -10.0 or 51.0)
        end
    end
end)

callbacks.Register("Unload", function()
    if cv_chat_time then cv_chat_time.SetFloat(cv_chat_time.ptr, 12.0) end
    if cv_vmodel_fov then cv_vmodel_fov.SetFloat(cv_vmodel_fov.ptr, 51.0) end
end)
