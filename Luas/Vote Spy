--Vote Controller Hud shii with netvars

local ref    = gui.Reference("Visuals", "Other")
local gb     = gui.Groupbox(ref, "Vote HUD", 325, 315, 300, 0)
local enable = gui.Checkbox(gb, "vh.enable", "Enable", false)
local show_inactive = gui.Checkbox(gb, "vh.inactive", "Oylama Yoksa Gizle", true)

local font_big = draw.CreateFont("Tahoma", 15, 700)
local font_sm  = draw.CreateFont("Tahoma", 12, 600)

local TEAM_NAMES = { [0]="HERKES", [2]="SURVIVOR", [3]="INFECTED" }

local active_issue = ""
client.AllowListener("vote_started")
client.AllowListener("vote_passed")
client.AllowListener("vote_failed")
client.AllowListener("vote_ended")

callbacks.Register("FireGameEvent", "vh_ev", function(event)
    local n = event:GetName()
    if n == "vote_started" then
        active_issue = event:GetString("issue") or "?"
    elseif n == "vote_passed" or n == "vote_failed" or n == "vote_ended" then
        active_issue = ""
    end
end)

callbacks.Register("Draw", "vh_draw", function()
    if not enable:GetValue() then return end

    local vc = entities.FindByClass("CVoteController")
    if not vc or not vc[1] then return end
    local e = vc[1]

    local ok1, issue   = pcall(function() return e:GetPropInt("m_activeIssueIndex") end)
    local ok2, teamv   = pcall(function() return e:GetPropInt("m_onlyTeamToVote") end)
    local ok3, yes     = pcall(function() return e:GetPropInt("m_votesYes") end)
    local ok4, no      = pcall(function() return e:GetPropInt("m_votesNo") end)
    local ok5, total   = pcall(function() return e:GetPropInt("m_potentialVotes") end)

    if not ok1 then return end

    local active = ok1 and issue and issue >= 0
    if not active and show_inactive:GetValue() then return end

    local sw, sh = draw.GetScreenSize()
    local pad  = 10
    local w    = 260
    local h    = active and 100 or 40
    local px   = sw/2 - w/2
    local py   = 30

    draw.Color(0, 0, 0, 180)
    draw.FilledRect(px, py, px+w, py+h)
    draw.Color(active and 255 or 80, active and 220 or 80, active and 50 or 80, 200)
    draw.OutlinedRect(px, py, px+w, py+h)

    draw.SetFont(font_big)

    if not active then
        local txt = "Oylama Yok"
        local tw, _ = draw.GetTextSize(txt)
        draw.Color(120, 120, 120, 200)
        draw.Text(px+w/2-tw/2, py+10, txt)
        return
    end

    local issueTxt = active_issue ~= "" and active_issue or ("Issue #"..issue)
    local itw, _ = draw.GetTextSize(issueTxt)
    draw.Color(255, 220, 50, 255)
    draw.Text(px+w/2-itw/2, py+pad, issueTxt)

    draw.SetFont(font_sm)
    local teamStr = "Oy: " .. (TEAM_NAMES[ok2 and teamv or 0] or "?")
    local ttw, _ = draw.GetTextSize(teamStr)
    draw.Color(180, 180, 180, 220)
    draw.Text(px+w/2-ttw/2, py+28, teamStr)

    local yesV  = ok3 and yes   or 0
    local noV   = ok4 and no    or 0
    local totV  = ok5 and total or 0

    local yTxt = string.format("EVET: %d", yesV)
    local nTxt = string.format("HAYIR: %d", noV)
    local tTxt = string.format("/ %d", totV)

    draw.Color(80, 220, 80, 255)
    draw.Text(px+pad, py+46, yTxt)
    draw.Color(255, 80, 80, 255)
    local ntw, _ = draw.GetTextSize(nTxt)
    draw.Text(px+w-ntw-pad, py+46, nTxt)
    draw.Color(200, 200, 200, 200)
    local ttw2, _ = draw.GetTextSize(tTxt)
    draw.Text(px+w/2-ttw2/2, py+46, tTxt)

    local barX = px+pad
    local barY = py+66
    local barW = w - pad*2
    local barH = 8

    draw.Color(25, 25, 25, 220)
    draw.FilledRect(barX, barY, barX+barW, barY+barH)

    if totV > 0 then
        local yesFill = math.floor(barW * yesV / totV)
        local noFill  = math.floor(barW * noV  / totV)

        draw.Color(80, 220, 80, 220)
        draw.FilledRect(barX, barY, barX+yesFill, barY+barH)
        draw.Color(255, 80, 80, 220)
        draw.FilledRect(barX+barW-noFill, barY, barX+barW, barY+barH)
    end

    draw.Color(100, 100, 100, 180)
    draw.OutlinedRect(barX, barY, barX+barW, barY+barH)

    local midX = barX + barW/2
    draw.Color(200, 200, 200, 100)
    draw.Line(midX, barY, midX, barY+barH)

    if totV > 0 then
        local pct = string.format("%.0f%%", yesV/totV*100)
        draw.SetFont(font_sm)
        local pw, _ = draw.GetTextSize(pct)
        draw.Color(0, 0, 0, 180)
        draw.Text(barX+barW/2-pw/2+1, barY-14+1, pct)
        draw.Color(255, 255, 255, 220)
        draw.Text(barX+barW/2-pw/2, barY-14, pct)
    end
end)




