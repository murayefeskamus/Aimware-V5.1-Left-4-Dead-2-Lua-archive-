local font = draw.CreateFont("Tahoma", 14, 800)
local hits  = {}

client.AllowListener("ammo_pickup")

callbacks.Register("FireGameEvent", function(event)
    if event:GetName() ~= "ammo_pickup" then return end
    local userid = event:GetInt("userid")
    local ent    = entities.GetByIndex(client.GetPlayerIndexByUserID(userid))
    if not ent then return end
    local pos = ent:GetAbsOrigin()
    if not pos then return end
    table.insert(hits, {
        pos    = pos,
        time   = globals.RealTime(),
        expire = globals.RealTime() + 3.5,
    })
end)

callbacks.Register("Draw", "ammo_pickup_draw", function()
    local now = globals.RealTime()
    local i   = 1
    while i <= #hits do
        local h = hits[i]
        if now > h.expire then
            table.remove(hits, i)
        else
            local age   = now - h.time
            local alpha
            if age < 2.0 then
                alpha = 255
            else
                alpha = math.max(0, math.floor(255 * (1 - (age - 2.0) / 1.5)))
            end
            local floatY = math.floor(age * 25)

            local sx, sy = client.WorldToScreen(h.pos + Vector3(0,0,60))
            if sx and sy then
                draw.SetFont(font)
                local tw, _ = draw.GetTextSize("PICKED")
                draw.Color(0,0,0,math.floor(alpha*0.6))
                draw.Text(sx-tw/2+1, sy-floatY+1, "PICKED")
                draw.Color(50, 255, 80, alpha)
                draw.Text(sx-tw/2, sy-floatY, "PICKED")
            end
            i = i + 1
        end
    end
end)
